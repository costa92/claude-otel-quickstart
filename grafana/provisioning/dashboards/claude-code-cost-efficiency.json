    {
      "id": 13,
      "title": "Top 20 最贵 Prompt (点 Prompt ID 下钻)",
      "type": "table",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "按 prompt 聚合的花费排行。点 Prompt ID 跳到 Prompt Detail 拆解 token/cost/工具调用。",
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "topk(20, sum by (prompt_id, model, process_pid) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cost_usd [$__range])))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "instant": true,
          "range": false,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Cost (USD)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt ID"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "拆解此 Prompt (Prompt Detail) →",
                    "url": "/d/claude-code-prompt-detail/claude-code-prompt-detail?var-prompt_id=${__data.fields[\"Prompt ID\"]}&var-process=${__data.fields.PID}&${__url_time_range}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "PID"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Trace (执行流程) →",
                    "targetBlank": false,
                    "url": "/d/claude-code-trace/claude-code-prompt-trace?var-prompt_id=${__data.fields[\"Prompt ID\"]}&var-process=${__data.fields.PID}&${__url_time_range}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "prompt_id": 0,
              "model": 1,
              "process_pid": 2,
              "Value": 3
            },
            "renameByName": {
              "prompt_id": "Prompt ID",
              "model": "Model",
              "process_pid": "PID",
              "Value": "Cost (USD)"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Cost (USD)",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "id": 14,
      "title": "成本按 effort 级别 (找贵请求根因)",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "thinking effort(high/none 等)× model 的花费分解。高 effort 占比大=优化点。",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 39
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "queryType": "instant",
          "instant": true,
          "range": false,
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "expr": "sum by (effort, model) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cost_usd [$__range]))",
          "legendFormat": "{{model}} / effort={{effort}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "continuous-GrYlRd"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 15,
      "title": "Edit 接受率 (区间)",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "区间内 Write/Edit/MultiEdit 的 tool_decision 中 accept 占比(来自 Loki 事件,尊重时间范围)。skip-permissions 下恒 100%;交互模式=你采纳 Claude 编辑的比例。",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 47
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "queryType": "instant",
          "instant": true,
          "range": false,
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_decision\" | process_pid=~\"$process\" | tool_name=~\"Write|Edit|MultiEdit|NotebookEdit\" | decision=\"accept\" [$__range])) / sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_decision\" | process_pid=~\"$process\" | tool_name=~\"Write|Edit|MultiEdit|NotebookEdit\" [$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0",
          "color": {
            "mode": "thresholds"
          },
