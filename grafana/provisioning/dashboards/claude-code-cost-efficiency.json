{
  "id": null,
  "uid": "claude-code-cost-efficiency",
  "title": "Claude Code - Cost & Efficiency 优化",
  "tags": [
    "claude-code"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "process",
        "type": "textbox",
        "label": "Process PID (正则,默认全部)",
        "query": ".*",
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "options": [
          {
            "text": ".*",
            "value": ".*",
            "selected": true
          }
        ]
      }
    ]
  },
  "links": [
    {
      "asDropdown": true,
      "icon": "apps",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "claude-code"
      ],
      "targetBlank": false,
      "title": "📊 Claude Code 面板",
      "type": "dashboards"
    },
    {
      "title": "← Overview",
      "type": "link",
      "url": "/d/claude-code-overview/",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Sessions",
      "type": "link",
      "url": "/d/claude-code-sessions/",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Prompt Detail",
      "type": "link",
      "url": "/d/claude-code-prompt-detail/",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Cache 命中率 (区间)",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "cache_read / (cache_read + cache_creation + fresh input)。越高越省钱:命中的上下文按 ~10% 价计费。",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_read_tokens [$__range])) / (sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_read_tokens [$__range])) + sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_creation_tokens [$__range])) + sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap input_tokens [$__range])))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.4
              },
              {
                "color": "green",
                "value": 0.7
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "title": "区间累计成本",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "所选时间范围内全部 api_request 的 cost_usd 之和。",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cost_usd [$__range]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Cache Read 总量",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "命中缓存的输入 token 总量(按 ~10% 价计费的部分)。",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_read_tokens [$__range]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "instant": true,
          "range": false
