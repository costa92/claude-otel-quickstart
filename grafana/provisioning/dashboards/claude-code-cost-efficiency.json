        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "title": "Token 构成趋势 (cache_read / cache_creation / fresh input)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "缓存命中(cache_read,便宜)应远大于另两者才算高效。",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_read_tokens [$__interval]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "range": true,
          "legendFormat": "cache_read"
        },
        {
          "refId": "B",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_creation_tokens [$__interval]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "range": true,
          "legendFormat": "cache_creation"
        },
        {
          "refId": "C",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap input_tokens [$__interval]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "range": true,
          "legendFormat": "fresh_input"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "title": "成本燃烧率 ($/bucket, 按模型)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "每个时间桶的花费,按模型分层。看燃烧节奏和贵模型尖峰。",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cost_usd [$__interval]))",
