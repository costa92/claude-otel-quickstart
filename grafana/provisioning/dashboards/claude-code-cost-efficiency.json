      }
    },
    {
      "id": 4,
      "title": "平均 API 延迟",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "api_request duration_ms 的均值。",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "avg(avg_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap duration_ms [$__range]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
