    {
      "id": 10,
      "title": "工具失败率 (区间)",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "success=false 的 tool_result 占比。0 失败时显示 0%。",
      "gridPos": {
