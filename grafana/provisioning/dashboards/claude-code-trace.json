{
  "id": null,
  "links": [
    {
      "icon": "arrow-left",
      "includeVars": false,
      "keepTime": true,
      "title": "Back to Prompt Detail",
      "type": "link",
      "url": "/d/claude-code-prompt-detail/claude-code-prompt-detail?var-prompt_id=${prompt_id}&var-process=${process}&from=${__from}&to=${__to}"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "本 prompt 下的完整执行流(按 event_sequence 排序): user_prompt → api_request → tool_result / tool_decision / skill_activated / mcp_server_connection 一条不漏。注意: Claude 2.1.153 的 OTel SDK 没填 trace_id/span_id, 所以用 prompt_id 作逻辑 trace key。",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "wrap": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "seq"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "at"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 130
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "event"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 200
              },
              {
                "id": "custom.wrapText",
                "value": false
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "summary"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 1100
              },
              {
                "id": "custom.wrapText",
                "value": true
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 40,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "seq"
          }
        ]
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} | prompt_id=~\"$prompt_id\" | process_pid=~\"$process\" | event_name=~\"user_prompt|api_request|tool_result|tool_decision|skill_activated|mcp_server_connection\" | line_format ` {\"seq\":{{printf \"%s\" .event_sequence}},\"at\":{{printf \"%q\" (date \"15:04:05.000\" (unixToTime (printf \"%d\" (add 28800 (unixEpoch (toDate \"2006-01-02T15:04:05.000Z\" .event_timestamp))))))}},\"event\":{{printf \"%q\" .event_name}},\"summary\":\"{{if .tool_name}}{{printf \"%s\" .tool_name}} | ok={{.success}} | in={{.tool_input_size_bytes}}B out={{.tool_result_size_bytes}}B | dur={{.duration_ms}}ms{{else if .model}}{{printf \"%s\" .model}} | in={{.input_tokens}} out={{.output_tokens}} | cache_read={{.cache_read_tokens}} | cost=${{.cost_usd}}{{else if .prompt}}{{printf \"%s\" .prompt}}{{else if .skill_name}}{{printf \"skill=%s trigger=%s source=%s\" .skill_name .invocation_trigger .skill_source}}{{else if .server_name}}{{printf \"mcp_server=%s tools=%s\" .server_name .tool_name}}{{end}}\"}`",
          "refId": "A"
        }
      ],
      "title": "Trace Timeline (all events, ordered by sequence)",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "json",
            "keepTime": false,
            "replaceSpaceWith": "",
            "source": "Line",
            "trim": true
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "Time": true,
              "id": true,
              "labelTypes": true,
              "labels": true,
              "tsNs": true
            },
            "indexByName": {
              "at": 1,
              "event": 2,
              "seq": 0,
              "summary": 3
            },
            "renameByName": {
              "at": "At",
              "event": "Event",
              "seq": "Seq",
              "summary": "Summary"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "claude-code",
    "prompts",
    "trace"
  ],
  "templating": {
    "list": [
      {
        "name": "process",
        "type": "textbox",
        "label": "Process",
        "current": {
          "text": ".*",
          "value": ".*"
        },
        "query": ".*"
      },
      {
        "name": "prompt_id",
        "type": "query",
        "label": "Prompt ID",
        "datasource": {
          "type": "loki",
          "uid": "loki-claude-code"
        },
        "query": "{service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\"",
        "queryValue": "",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Claude Code - Prompt Trace",
  "uid": "claude-code-trace"
}