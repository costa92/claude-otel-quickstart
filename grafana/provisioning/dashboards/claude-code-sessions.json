{
  "title": "Claude Code - Sessions",
  "uid": "claude-code-sessions",
  "tags": [
    "claude-code",
    "sessions"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "links": [
    {
      "title": "User Prompts (二级页面) →",
      "url": "/d/claude-code-user-prompts/claude-code-user-prompts",
      "type": "link",
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "process",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki-claude-code"
        },
        "query": "{service_name=\"claude-code\"} | event_name=\"user_prompt\"",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Prompts (1h)",
      "description": "1h 内 user_prompt 事件数 = 发了多少次问。plugin_loaded 24h 才 3 条太稀疏,改用 user_prompt 让 5m/1h 窗口都有数据。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Top User (1h, by prompts)",
      "description": "1h 内发问最多的 user (OTel SDK 发的是 user_id, 不是 user_email)。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(1, sum by (user_id) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "{{user_email}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Top Device (1h, by prompts)",
      "description": "1h 内最常用的设备(arch+os+version)。要细到 host.name 需设 OTEL_RESOURCE_ATTRIBUTES。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(1, sum by (host_arch, os_type, os_version) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "{{host_arch}} {{os_type}} {{os_version}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Top Claude Version (1h, by prompts)",
      "description": "1h 内团队主要用的 Claude 版本。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(1, sum by (service_version) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "v{{service_version}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "User Prompts List (1h, with session metadata)",
      "description": "1h 内每次 user_prompt 一行: Started / Prompt ID / User / Arch / OS / Claude / Terminal / Process / Len。plugin_loaded 24h 才 3 条,改用 user_prompt 让 5m/1h 都有数据。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" | line_format `{\"started_at\": \"{{.event_timestamp}}\", \"prompt_id\": \"{{.prompt_id}}\", \"user_id\": \"{{.user_id}}\", \"process\": \"{{.process_pid}}\", \"arch\": \"{{.host arch}}\", \"os\": \"{{.os_type}}\", \"os_ver\": \"{{.os_version}}\", \"claude\": \"v{{.service_version}}\", \"terminal\": \"{{.terminal_type}}\", \"len\": \"{{.prompt_length}}\", \"cwd\": \"{{.process_executable_path}}\"}`"
        }
      ],
      "options": {
        "showTime": false,
        "showLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false,
        "prettifyLogMessage": false
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json",
            "replaceSpaceWith": "",
            "trim": true,
            "keepTime": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "tsNs": true,
              "labelTypes": true,
              "id": true,
              "event_timestamp": true,
              "started": true,
              "Time": true,
              "prompt": true
            },
            "renameByName": {
              "started_at": "Started",
              "prompt_id": "Prompt ID",
              "len": "Len"
            },
            "indexByName": {
              "started_at": 0,
              "user_id": 2,
              "arch": 3,
              "os": 4,
              "os_ver": 5,
              "claude": 6,
              "terminal": 7,
              "process": 9,
              "prompt_id": 1,
              "len": 8
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "started_at"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 220
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt ID"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 290
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "user_id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "arch"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "os"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "os_ver"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "claude"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "terminal"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "plugin_scope"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "process"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "links",
                "value": [
                  {
                    "title": "View prompts for session ${__data.fields.process} →",
                    "url": "/d/claude-code-sessions-prompts/claude-code-user-prompts?var-process=${__data.fields.process}&from=${__data.fields.started_at}&to=now",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent User Prompts (raw stream)",
      "description": "展开看每条 user_prompt 事件的具体 prompt_id, 可关联到上面 table",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\"",
          "legendFormat": "{{user_email}}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "showCommonLabels": false,
        "prettifyLogMessage": true,
        "dedupStrategy": "none"
      }
    }
  ]
}