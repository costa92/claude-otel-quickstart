{
  "title": "Claude Code - Sessions",
  "uid": "claude-code-sessions",
  "tags": [
    "claude-code",
    "sessions"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "links": [
    {
      "asDropdown": true,
      "icon": "apps",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "claude-code"
      ],
      "targetBlank": false,
      "title": "📊 Claude Code 面板",
      "type": "dashboards"
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "process",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki-claude-code"
        },
        "query": "sum by (process_pid) (count_over_time({service_name=\"claude-code\"} |= \"user_prompt\" | process_pid =~ \".+\" [$__range]))",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "allValue": ".+"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Prompts (1h)",
      "description": "1h 内 user_prompt 事件数 = 发了多少次问。plugin_loaded 24h 才 3 条太稀疏,改用 user_prompt 让 5m/1h 窗口都有数据。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Top User (1h, by prompts)",
      "description": "1h 内发问最多的 user (OTel SDK 发的是 user_id, 不是 user_email)。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(1, sum by (user_id) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "{{user_id}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Top Device (1h, by prompts)",
      "description": "1h 内最常用的设备(arch+os+version)。要细到 host.name 需设 OTEL_RESOURCE_ATTRIBUTES。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(1, sum by (host_arch, os_type, os_version) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "{{host_arch}} {{os_type}} {{os_version}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Top Claude Version (1h, by prompts)",
      "description": "1h 内团队主要用的 Claude 版本。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(1, sum by (service_version) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "v{{service_version}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "User Prompts List (1h, with session metadata)",
      "description": "1h 内每次 user_prompt 一行: Started / Prompt ID / User / Arch / OS / Claude / Terminal / Process / Len。plugin_loaded 24h 才 3 条,改用 user_prompt 让 5m/1h 都有数据。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" | line_format `{\"started_at\": \"{{.event_timestamp}}\", \"prompt_id\": \"{{.prompt_id}}\", \"user_id\": \"{{.user_id}}\", \"process\": \"{{.process_pid}}\", \"arch\": \"{{.host_arch}}\", \"os\": \"{{.os_type}}\", \"os_ver\": \"{{.os_version}}\", \"claude\": \"v{{.service_version}}\", \"terminal\": \"{{.terminal_type}}\", \"len\": \"{{.prompt_length}}\", \"cwd\": \"{{.process_executable_path}}\"}`"
        }
      ],
      "options": {
        "showTime": false,
        "showLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": false,
        "prettifyLogMessage": false
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json",
            "replaceSpaceWith": "",
            "trim": true,
            "keepTime": false
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true,
              "tsNs": true,
              "labelTypes": true,
              "id": true,
              "event_timestamp": true,
              "started": true,
              "Time": true,
              "prompt": true
            },
            "renameByName": {
              "started_at": "Started",
              "prompt_id": "Prompt ID",
              "len": "Len"
            },
            "indexByName": {
              "started_at": 0,
              "user_id": 2,
              "arch": 3,
              "os": 4,
              "os_ver": 5,
              "claude": 6,
              "terminal": 7,
              "process": 9,
              "prompt_id": 1,
              "len": 8
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "started_at"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 220
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt ID"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 290
              },
              {
                "id": "links",
                "value": [
                  {
                    "title": "Prompt Detail (拆解) →",
                    "targetBlank": false,
                    "url": "/d/claude-code-prompt-detail/claude-code-prompt-detail?var-prompt_id=${__data.fields[\"Prompt ID\"]}&var-process=${__data.fields.process}&${__url_time_range}"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "user_id"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "arch"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "os"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "os_ver"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "claude"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "terminal"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "plugin_scope"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 110
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "process"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "links",
                "value": [
                  {
                    "title": "View prompts for session ${__data.fields.process} →",
                    "url": "/d/claude-code-sessions-prompts/claude-code-user-prompts?var-process=${__data.fields.process}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Started"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Trace (执行流程) →",
                    "targetBlank": false,
                    "url": "/d/claude-code-trace/claude-code-prompt-trace?var-prompt_id=${__data.fields[\"Prompt ID\"]}&var-process=${__data.fields.process}&${__url_time_range}"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "Recent User Prompts (raw stream)",
      "description": "展开看每条 user_prompt 事件的具体 prompt_id, 可关联到上面 table",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\"",
          "legendFormat": "{{user_email}}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "showCommonLabels": false,
        "prettifyLogMessage": true,
        "dedupStrategy": "none"
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Sessions List (每个会话一行 · 含 Resume ID)",
      "description": "按 (process_pid, session_id) 分组,一行=一个会话。点 PID 列下钻到 User Prompts / Prompt Trace(带本会话 pid 过滤)。Resume ID 即 claude --resume <id>。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 11
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "expr": "{service_name=\"claude-code\"} |= \"user_prompt\" | process_pid =~ \"$process\"",
          "queryType": "range",
          "maxLines": 2000
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels",
            "keepTime": true,
            "replace": false
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "session_id": {
                "operation": "groupby",
                "aggregations": []
              },
              "process_pid": {
                "operation": "groupby",
                "aggregations": []
              },
              "Time": {
                "operation": "aggregate",
                "aggregations": [
                  "min",
                  "max"
                ]
              },
              "user_id": {
                "operation": "aggregate",
                "aggregations": [
                  "first"
                ]
              },
              "host_name": {
                "operation": "aggregate",
                "aggregations": [
                  "first"
                ]
              },
              "service_version": {
                "operation": "aggregate",
                "aggregations": [
                  "first"
                ]
              },
              "process_executable_path": {
                "operation": "aggregate",
                "aggregations": [
                  "first"
                ]
              },
              "Line": {
                "operation": "aggregate",
                "aggregations": [
                  "count"
                ]
              }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {
              "session_id": "Resume ID (session.id)",
              "process_pid": "PID",
              "Time (min)": "First Prompt",
              "Time (max)": "Last Prompt",
              "Line (count)": "Prompts",
              "user_id (first)": "User",
              "host_name (first)": "Host",
              "service_version (first)": "Version",
              "process_executable_path (first)": "CWD"
            },
            "indexByName": {
              "session_id": 0,
              "process_pid": 1,
              "Line (count)": 2,
              "Time (min)": 3,
              "Time (max)": 4,
              "user_id (first)": 5,
              "host_name (first)": 6,
              "service_version (first)": 7,
              "process_executable_path (first)": 8
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Resume ID (session.id)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 300
              },
              {
                "id": "links",
                "value": [
                  {
                    "title": "Prompt Trace (本会话) →",
                    "url": "/d/claude-code-trace/claude-code-prompt-trace?var-process=${__data.fields[\"PID\"]}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Prompts"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-BlPu"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "PID"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "User Prompts (本会话) →",
                    "url": "/d/claude-code-sessions-prompts/claude-code-user-prompts?var-process=${__data.fields[\"PID\"]}&${__url_time_range}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Last Prompt",
            "desc": true
          }
        ]
      }
    }
  ]
}