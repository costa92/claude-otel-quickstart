{
  "title": "Claude Code Overview",
  "uid": "claude-code-overview",
  "tags": [
    "claude-code"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-claude-code"
        },
        "query": "label_values(claude_code_cost_usage_USD_total, team)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Cost (USD)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_cost_usage_USD_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "noValue": "0"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sessions",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_session_count_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Time",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_active_time_seconds_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_token_usage_tokens_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tokens by Type",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (claude_code_token_usage_tokens_total{team=~\"$team\"})",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cost by Team / Model",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (team, model) (claude_code_cost_usage_USD_total{team=~\"$team\"})",
          "legendFormat": "{{team}} / {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Tokens by Skill Category",
      "description": "实测 skill_name 是分类(third-party/built-in)而非具体 skill 名。需要 OTEL_LOG_TOOL_DETAILS=1 且会话有 Skill 调用",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (skill_name) (claude_code_token_usage_tokens_total{skill_name!=\"\",team=~\"$team\"})",
          "legendFormat": "{{skill_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        }
      }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Cost by Plugin Category (USD)",
      "description": "plugin_name 也是分类。要看具体 plugin 调用得走 Loki 查 tool_result events",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (plugin_name) (claude_code_cost_usage_USD_total{plugin_name!=\"\",team=~\"$team\"})",
          "legendFormat": "{{plugin_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "continuous-YlRd"
          }
        }
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Top 10 Subagents by Tokens (具体名)",
      "description": "agent_name 是具体 subagent 名(general-purpose / 自定义 agent)。这条最有用",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (agent_name) (claude_code_token_usage_tokens_total{agent_name!=\"\",team=~\"$team\"}))",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        }
      }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "MCP Server Call Frequency (from Loki logs)",
      "description": "MCP 调用频率,按 server 分组。来自 Loki mcp_server_connection 事件的 server_name label (已过滤空 server_name)",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (server_name) (count_over_time({service_name=\"claude-code\"} | event_name=\"mcp_server_connection\" | server_name!=\"\" [$__range]))",
          "legendFormat": "{{server_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-purples"
          }
        }
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Recent MCP Connections (server / 状态 / transport)",
      "description": "最近的 MCP 服务器连接事件,含 connected/failed/disconnected 状态。原\"Recent MCP Tool Calls\"用 mcp_tool 几乎无数据,改为连接流以在概览直接暴露连接失败。",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | event_name=\"mcp_server_connection\" | line_format `{{.server_name}} | {{.status}} | {{.transport_type}} | scope={{.server_scope}} | {{.duration_ms}}ms`"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Commits (累计)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "description": "Claude 代为 git commit 的累计次数(claude_code_commit_count_total,OTLP 累计 counter)。",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_commit_count_total[$__range]))",
          "datasource": {
            "type": "prometheus",
            "uid": "prom-claude-code"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "工具失败率 (区间)",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "tool_result 中 success=false 占比。>0 说明有工具执行失败需关注。api_error(API层失败)当前无数据,发生时另见 Trace。",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "queryType": "instant",
          "instant": true,
          "range": false,
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | success=\"false\" [$__range])) / sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" [$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "noValue": "0",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "red",
                "value": 0.2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    }
  ],
  "links": [
    {
      "asDropdown": true,
      "icon": "apps",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "claude-code"
      ],
      "targetBlank": false,
      "title": "📊 Claude Code 面板",
      "type": "dashboards"
    }
  ]
}