{
  "title": "Claude Code Overview",
  "uid": "claude-code-overview",
  "tags": [
    "claude-code"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-claude-code"
        },
        "query": "label_values(claude_code_cost_usage_USD_total, team)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Cost (USD)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_cost_usage_USD_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "noValue": "0"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sessions",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_session_count_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Time",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_active_time_seconds_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(last_over_time(claude_code_token_usage_tokens_total{team=~\"$team\"}[$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tokens by Type",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (claude_code_token_usage_tokens_total{team=~\"$team\"})",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cost by Team / Model",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (team, model) (claude_code_cost_usage_USD_total{team=~\"$team\"})",
          "legendFormat": "{{team}} / {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Tokens by Skill Category",
      "description": "实测 skill_name 是分类(third-party/built-in)而非具体 skill 名。需要 OTEL_LOG_TOOL_DETAILS=1 且会话有 Skill 调用",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (skill_name) (claude_code_token_usage_tokens_total{skill_name!=\"\",team=~\"$team\"})",
          "legendFormat": "{{skill_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        }
      }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Cost by Plugin Category (USD)",
      "description": "plugin_name 也是分类。要看具体 plugin 调用得走 Loki 查 tool_result events",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (plugin_name) (claude_code_cost_usage_USD_total{plugin_name!=\"\",team=~\"$team\"})",
          "legendFormat": "{{plugin_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "continuous-YlRd"
          }
        }
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Top 10 Subagents by Tokens (具体名)",
      "description": "agent_name 是具体 subagent 名(general-purpose / 自定义 agent)。这条最有用",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (agent_name) (claude_code_token_usage_tokens_total{agent_name!=\"\",team=~\"$team\"}))",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        }
      }
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "MCP Server Call Frequency (from Loki logs)",
      "description": "MCP 调用频率,按 server 分组。来自 Loki mcp_server_connection 事件的 server_name label",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (server_name) (count_over_time({service_name=\"claude-code\"} |= `mcp_server_connection` [1h]))",
          "legendFormat": "{{server_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-purples"
          }
        }
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Recent MCP Tool Calls (raw stream)",
      "description": "最近 MCP 调用的原始事件流(server + tool_name + 用时等)",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name=\"mcp_tool\" | line_format `{{ .tool_name }} -> ok={{ .success }} dur={{ .duration_ms }}ms`"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "links": [
    {
      "asDropdown": true,
      "icon": "apps",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "claude-code"
      ],
      "targetBlank": false,
      "title": "📊 Claude Code 面板",
      "type": "dashboards"
    }
  ]
}