{
  "title": "Claude Code Overview",
  "uid": "claude-code-overview",
  "tags": [
    "claude-code",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-claude-code"
        },
        "query": "label_values(claude_code_cost_usage_USD_total, team)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Cost (USD)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(claude_code_cost_usage_USD_total{team=~\"$team\"})"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sessions",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(claude_code_session_count_total{team=~\"$team\"})"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Time",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(claude_code_active_time_seconds_total{team=~\"$team\"})"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Tokens",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(claude_code_token_usage_tokens_total{team=~\"$team\"})"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tokens by Type",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (claude_code_token_usage_tokens_total{team=~\"$team\"})",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cost by Team / Model",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (team, model) (claude_code_cost_usage_USD_total{team=~\"$team\"})",
          "legendFormat": "{{team}} / {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Tokens by Subagent",
      "description": "按 subagent 类型拆分 token(general-purpose / Explore / Plan / 自定义)。Claude 2.1.153 实测: agent_name 是具体名,skill_name/plugin_name 是分类(永远只有 third-party 一根柱)",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (agent_name) (claude_code_token_usage_tokens_total{agent_name!=\"\",team=~\"$team\"})",
          "legendFormat": "{{agent_name}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-BlPu"
          }
        }
      }
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Cost by Model (USD)",
      "description": "按模型拆分成本(可看哪些模型在烧钱)。plugin_name 是分类永远单色所以换了",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (claude_code_cost_usage_USD_total{team=~\"$team\"})",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "continuous-YlRd"
          }
        }
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Top 10 Users by Cost (USD, 1h)",
      "description": "按 user_email 拆分成本。panel 7 已经按 subagent 拆分,这里换 user 维度看钱花在哪个人身上",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (user_email) (claude_code_cost_usage_USD_total{team=~\"$team\"}))",
          "legendFormat": "{{user_email}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": {
            "mode": "continuous-GrYlRd"
          }
        }
      }
    }
  ]
}