{
  "id": 7,
  "links": [
    {
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "title": "← Back to Sessions",
      "type": "link",
      "url": "/d/claude-code-sessions/claude-code-sessions?from=${__from}&to=${__to}"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "1h 内 user_prompt 事件数。注: Claude Code 默认 redact prompt 内容为 <REDACTED>; yoyo 需设 OTEL_LOG_USER_PROMPTS=1 才能看到真实文本",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h]))",
          "refId": "A"
        }
      ],
      "title": "Total User Prompts (1h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "1h 内 user_prompt 平均字符数",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "avg_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" | unwrap prompt_length [1h])",
          "legendFormat": "avg",
          "refId": "A"
        }
      ],
      "title": "Avg Prompt Length",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "1h 内发 prompt 最多的 user",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "topk(1, sum by (user_id) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "{{user_id}}",
          "refId": "A"
        }
      ],
      "title": "Top User (1h, by prompts)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "1h 内发 prompt 最多的 claude 进程(process.pid)",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "topk(1, sum by (process_pid) (count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "legendFormat": "{{process_pid}}",
          "refId": "A"
        }
      ],
      "title": "Top Process (1h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "每个 user_prompt 一行；按 prompt_id 汇总后续 api_request 的 input/output/cache tokens、cost，并用 unique values 显示本次 prompt 触发过的所有模型。",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "wrap": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Started"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 190
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt ID"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 290
              },
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": false,
                    "title": "Prompt detail ${__value.text} →",
                    "url": "/d/claude-code-prompt-detail/claude-code-prompt-detail?var-prompt_id=${__value.text}&var-process=${__data.fields.Process}&from=${__from}&to=${__to}&refresh=10s"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Process"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 80
              },
              {
                "id": "links",
                "value": [
                  {
                    "targetBlank": false,
                    "title": "Jump to Session ${__data.fields.Process} →",
                    "url": "/d/claude-code-sessions/claude-code-sessions?var-process=${__data.fields.Process}&from=now-1h&to=now"
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "User"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "In Tokens"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Out Tokens"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cache Read"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cache Create"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cost ($)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Models"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Len"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 60
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 760
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "auto"
                }
              },
              {
                "id": "custom.wrapText",
                "value": true
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 17,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 5,
      "options": {
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" | line_format ` {\"session_id\":{{printf \"%q\" .prompt_id}},\"started_at\":{{printf \"%q\" (date \"2006-01-02 15:04:05\" (unixToTime (printf \"%d\" (add 28800 (unixEpoch (toDate \"2006-01-02T15:04:05.000Z\" .event_timestamp))))))}},\"user_id\":{{printf \"%q\" .user_id}},\"process\":{{printf \"%q\" .process_pid}},\"len\":{{.prompt_length}},\"prompt\":{{printf \"%q\" .prompt}}}`",
          "refId": "A"
        },
        {
          "expr": "{service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | line_format ` {\"session_id\":{{printf \"%q\" .prompt_id}},\"in_tokens\":{{.input_tokens}},\"out_tokens\":{{.output_tokens}},\"cache_read_tokens\":{{.cache_read_tokens}},\"cache_create_tokens\":{{.cache_creation_tokens}},\"cost\":{{.cost_usd}},\"model\":{{printf \"%q\" .model}}}`",
          "refId": "B"
        }
      ],
      "title": "User Prompts (1h, only user_prompt rows)",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "json",
            "keepTime": false,
            "replaceSpaceWith": "",
            "source": "Line",
            "trim": true
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "cache_create_tokens": {
                "aggregations": [
                  "sum"
                ],
                "operation": "aggregate"
              },
              "cache_read_tokens": {
                "aggregations": [
                  "sum"
                ],
                "operation": "aggregate"
              },
              "cost": {
                "aggregations": [
                  "sum"
                ],
                "operation": "aggregate"
              },
              "in_tokens": {
                "aggregations": [
                  "sum"
                ],
                "operation": "aggregate"
              },
              "len": {
                "aggregations": [
                  "firstNotNull"
                ],
                "operation": "aggregate"
              },
              "model": {
                "aggregations": [
                  "uniqueValues"
                ],
                "operation": "aggregate"
              },
              "out_tokens": {
                "aggregations": [
                  "sum"
                ],
                "operation": "aggregate"
              },
              "process": {
                "aggregations": [
                  "firstNotNull"
                ],
                "operation": "aggregate"
              },
              "prompt": {
                "aggregations": [
                  "firstNotNull"
                ],
                "operation": "aggregate"
              },
              "session_id": {
                "aggregations": [],
                "operation": "groupby"
              },
              "started_at": {
                "aggregations": [
                  "firstNotNull"
                ],
                "operation": "aggregate"
              },
              "user_id": {
                "aggregations": [
                  "firstNotNull"
                ],
                "operation": "aggregate"
              }
            }
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "config": {
                  "id": "isNull",
                  "options": {}
                },
                "fieldName": "prompt (firstNotNull)"
              }
            ],
            "match": "all",
            "type": "exclude"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "Time": true,
              "id": true,
              "labelTypes": true,
              "labels": true,
              "tsNs": true
            },
            "indexByName": {
              "cache_create_tokens (sum)": 7,
              "cache_read_tokens (sum)": 6,
              "cost (sum)": 8,
              "in_tokens (sum)": 4,
              "len (firstNotNull)": 10,
              "model (uniqueValues)": 9,
              "out_tokens (sum)": 5,
              "process (firstNotNull)": 2,
              "prompt (firstNotNull)": 11,
              "session_id": 1,
              "started_at (firstNotNull)": 0,
              "user_id (firstNotNull)": 3
            },
            "renameByName": {
              "cache_create_tokens (sum)": "Cache Create",
              "cache_read_tokens (sum)": "Cache Read",
              "cost (sum)": "Cost ($)",
              "in_tokens (sum)": "In Tokens",
              "len (firstNotNull)": "Len",
              "model (uniqueValues)": "Models",
              "out_tokens (sum)": "Out Tokens",
              "process (firstNotNull)": "Process",
              "prompt (firstNotNull)": "Prompt",
              "session_id": "Prompt ID",
              "started_at (firstNotNull)": "Started",
              "user_id (firstNotNull)": "User"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "1h 窗口所有 user_prompt 对应 api_request 的 input_tokens 总和。",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 22
      },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap input_tokens [1h]))",
          "refId": "A"
        }
      ],
      "title": "Total In Tokens",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "1h 窗口所有 user_prompt 对应 api_request 的 output_tokens 总和。",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 22
      },
      "id": 8,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap output_tokens [1h]))",
          "refId": "A"
        }
      ],
      "title": "Total Out Tokens",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "1h 窗口所有 user_prompt 对应 api_request 的 cost_usd 总和。",
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 22
      },
      "id": 9,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cost_usd [1h]))",
          "refId": "A"
        }
      ],
      "title": "Total Cost",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "每次 user_prompt 的平均花费(Cost / Total Prompts)。",
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 22
      },
      "id": 10,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "(sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cost_usd [1h])) / sum(count_over_time({service_name=\"claude-code\"} | event_name=\"user_prompt\" | process_pid=~\"$process\" [1h])))",
          "refId": "A"
        }
      ],
      "title": "Avg Cost / Prompt",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "claude-code",
    "sessions",
    "prompts"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "loki",
          "uid": "loki-claude-code"
        },
        "includeAll": true,
        "multi": false,
        "name": "process",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "$__all"
          }
        ],
        "query": "{service_name=\"claude-code\"} | event_name=\"user_prompt\"",
        "queryValue": "",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Claude Code - User Prompts",
  "uid": "claude-code-sessions-prompts",
  "version": 41
