        "w": 24,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by(hour,dow)(count_over_time({service_name=\"claude-code\"} | process_pid=~\"$process\" | label_format hour=`{{ date \"15\" (unixToTime (printf \"%d\" (add 28800 (unixEpoch (toDate \"2006-01-02T15:04:05.000Z\" .event_timestamp))))) }}`,dow=`{{ date \"Mon\" (unixToTime (printf \"%d\" (add 28800 (unixEpoch (toDate \"2006-01-02T15:04:05.000Z\" .event_timestamp))))) }}` [$__range]))",
          "queryType": "instant",
