    {
      "id": 14,
      "title": "③ 工具成功率 (按 tool_name)",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "success=true 占比。偏低的工具说明该自动化环节常失败、需要人工兜底。注:100% 失败的工具(若有)不会出现在此(分子无该标签)。",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by(tool_name)(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | process_pid=~\"$process\" | success=\"true\" [$__range])) / sum by(tool_name)(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | process_pid=~\"$process\" [$__range]))",
          "queryType": "instant",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "instant": true,
          "range": false,
          "legendFormat": "{{tool_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
