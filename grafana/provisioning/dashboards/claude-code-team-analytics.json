    {
      "id": 5,
      "title": "① 团队 Token 消耗趋势 (窗口化, 按 type)",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "每个时间桶的实际 token 消耗(非累计)。用于看每天/每小时消耗多少、规划资源。注:team 标签不在 Loki 日志上,此处为团队整体合计,无法按子团队拆分。",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap input_tokens [$__interval]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "range": true,
          "legendFormat": "fresh_input"
        },
        {
          "refId": "B",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap output_tokens [$__interval]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "range": true,
          "legendFormat": "output"
        },
        {
          "refId": "C",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_read_tokens [$__interval]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "range": true,
          "legendFormat": "cache_read"
        },
        {
          "refId": "D",
          "editorMode": "code",
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name=\"api_request\" | process_pid=~\"$process\" | unwrap cache_creation_tokens [$__interval]))",
          "queryType": "range",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "range": true,
          "legendFormat": "cache_create"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
