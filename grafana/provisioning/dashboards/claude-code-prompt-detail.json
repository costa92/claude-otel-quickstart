  "panels": [
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "当前 prompt 的原始输入行。prompt 正文只有在 OTEL_LOG_USER_PROMPTS=1 时可见。",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "wrap": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 900
              },
              {
                "id": "custom.wrapText",
                "value": true
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt ID"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 290
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Started"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 190
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": false,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"} | event_name=\"user_prompt\" | prompt_id=\"$prompt_id\" | process_pid=~\"$process\" | line_format ` {\"started_at\":{{printf \"%q\" (date \"2006-01-02 15:04:05\" (unixToTime (printf \"%d\" (add 28800 (unixEpoch (toDate \"2006-01-02T15:04:05.000Z\" .event_timestamp))))))}},\"prompt_id\":{{printf \"%q\" .prompt_id}},\"process\":{{printf \"%q\" .process_pid}},\"user\":{{printf \"%q\" .user_id}},\"len\":{{.prompt_length}},\"prompt\":{{printf \"%q\" .prompt}}}`",
          "refId": "A"
        }
      ],
      "title": "Prompt",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "json",
            "keepTime": false,
            "replaceSpaceWith": "",
            "source": "Line",
            "trim": true
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "Time": true,
              "id": true,
              "labelTypes": true,
              "labels": true,
              "tsNs": true
            },
            "indexByName": {
              "len": 4,
              "process": 2,
              "prompt": 5,
              "prompt_id": 1,
              "started_at": 0,
              "user": 3
            },
            "renameByName": {
              "len": "Len",
              "process": "Process",
              "prompt": "Prompt",
              "prompt_id": "Prompt ID",
              "started_at": "Started",
              "user": "User"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "id": 2,
