{
  "title": "Claude Code - Skills",
  "uid": "claude-code-skills",
  "tags": [
    "claude-code",
    "skills"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "team",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prom-claude-code"
        },
        "query": "label_values(claude_code_cost_usage_USD_total, team)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Skill Calls (1h)",
      "description": "Loki 里 tool_name='Skill' 的事件数。Claude 2.1.153 实测: skill_name 不在 Prom metric 里,只在这里能看到具体 skill 名",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name=\"Skill\" [1h]))",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Skill"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Tool Calls (1h, all types)",
      "description": "1h 内所有 tool_result 事件数(不分类型)。Skills page 的总调用量基线",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"claude-code\"} |= `tool_result` [1h]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "MCP Tool Calls (1h)",
      "description": "tool_name='mcp_tool' 事件数(对比 Skill 看占比)。MCP 详情见 Claude Code - MCP Servers 页",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name=\"mcp_tool\" [1h]))",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "mcp_tool"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Skill Category Tokens (Prom, 仅分类)",
      "description": "Claude 2.1.153 实测: Prom 端 skill_name 永远是 'third-party' 一个值,这是分类标签,不是具体 skill 名",
      "datasource": {
        "type": "prometheus",
        "uid": "prom-claude-code"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(claude_code_token_usage_tokens_total{skill_name!=\"\",team=~\"$team\"})"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Recent Skill Invocations (raw stream)",
      "description": "Skill 工具调用的原始事件。展开 row 看 tool_parameters.skill_name 这个 JSON label (像 'superpowers:using-superpowers')",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"claude-code\"} | event_name=\"tool_result\" | tool_name=\"Skill\"",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "showCommonLabels": false,
        "prettifyLogMessage": true,
        "dedupStrategy": "none"
      }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Skill 使用排行 (具体名, 来自 skill_activated)",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "真实 skill_name(含 plugin:skill 全名)。这是唯一能看到具体用了哪个 skill 的数据源 —— tool_result 不带 skill 名。",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "topk(15, sum by(skill_name)(count_over_time({service_name=\"claude-code\"} | event_name=\"skill_activated\" [$__range])))",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "queryType": "instant",
          "instant": true,
          "range": false,
          "legendFormat": "{{skill_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "noValue": "区间内无 skill 激活(skill 较稀疏,试着把时间拉到 7d/30d)"
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Skill 来源分布 (skill_source)",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "plugin / userSettings / project 等。看大家用的是插件市场的 skill 还是自建。",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by(skill_source)(count_over_time({service_name=\"claude-code\"} | event_name=\"skill_activated\" [$__range]))",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "queryType": "instant",
          "instant": true,
          "range": false,
          "legendFormat": "{{skill_source}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "无数据"
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Skill 触发方式 (invocation_trigger)",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "user-slash(用户 /命令) / nested-skill(技能内调技能) / 自动 等触发来源占比。",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "sum by(invocation_trigger)(count_over_time({service_name=\"claude-code\"} | event_name=\"skill_activated\" [$__range]))",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "queryType": "instant",
          "instant": true,
          "range": false,
          "legendFormat": "{{invocation_trigger}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "无数据"
        },
        "overrides": []
      },
      "options": {
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Recent Skill Activations (含 skill 名 / 来源 / 触发, 点 Prompt ID 看执行流程)",
      "datasource": {
        "type": "loki",
        "uid": "loki-claude-code"
      },
      "description": "每次 skill_activated 一行,含具体 skill 名。点 Prompt ID 跳 Trace 看该 skill 在哪条 prompt 的执行流程里被触发。",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "{service_name=\"claude-code\"} | event_name=\"skill_activated\" | line_format `{\"at\":{{printf \"%q\" (date \"01-02 15:04:05\" (unixToTime (printf \"%d\" (add 28800 (unixEpoch (toDate \"2006-01-02T15:04:05.000Z\" .event_timestamp))))))}},\"skill\":{{printf \"%q\" .skill_name}},\"source\":{{printf \"%q\" .skill_source}},\"trigger\":{{printf \"%q\" .invocation_trigger}},\"scope\":{{printf \"%q\" .scope_name}},\"prompt_id\":{{printf \"%q\" .prompt_id}},\"process\":{{printf \"%q\" .process_pid}}}`",
          "datasource": {
            "type": "loki",
            "uid": "loki-claude-code"
          },
          "queryType": "range",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Prompt ID"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Trace (执行流程) →",
                    "url": "/d/claude-code-trace/claude-code-prompt-trace?var-prompt_id=${__data.fields[\"Prompt ID\"]}&var-process=${__data.fields.Process}&${__url_time_range}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "Line",
            "format": "json",
            "replace": true,
            "keepTime": true
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "indexByName": {
              "at": 0,
              "skill": 1,
              "source": 2,
              "trigger": 3,
              "scope": 4,
              "prompt_id": 5,
              "process": 6
            },
            "renameByName": {
              "at": "At",
              "skill": "Skill",
              "source": "Source",
              "trigger": "Trigger",
              "scope": "Scope",
              "prompt_id": "Prompt ID",
              "process": "Process"
            }
          }
        }
      ]
    }
  ],
  "links": [
    {
      "asDropdown": true,
      "icon": "apps",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "claude-code"
      ],
      "targetBlank": false,
      "title": "📊 Claude Code 面板",
      "type": "dashboards"
    }
  ]
}